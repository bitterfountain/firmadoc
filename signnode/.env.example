# Configuracion del nodo de firma casero (sign_server.py)
# Genera el token:  openssl rand -hex 32
SIGN_AUTH_TOKEN=CAMBIA_ESTE_TOKEN
SIGN_PORT=8731
SIGN_BIND=127.0.0.1

# pyHanko firmara con el token via este script (copia el de FirmaDoc: scripts/pades_sign.py)
PADES_SCRIPT=/home/USUARIO/signnode/pades_sign.py
PYTHON=/home/USUARIO/signnode/.venv/bin/python

# Modulo PKCS#11 del token (lo da el fabricante / Disig). Ejemplos:
#   OpenSC:        /usr/lib/x86_64-linux-gnu/opensc-pkcs11.so
#   SafeNet:       /usr/lib/libeToken.so
PKCS11_LIB=/usr/lib/x86_64-linux-gnu/opensc-pkcs11.so
PKCS11_SLOT=
PKCS11_TOKEN=
PKCS11_CERT_LABEL=
PKCS11_KEY_LABEL=
PKCS11_PIN=

# Sello de tiempo (recomendado) y LTV (PAdES-LTA)
TSA_URL=http://timestamp.digicert.com
LTV=1
